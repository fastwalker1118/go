<mujoco model="fr3_pick_place">
  <!-- FR3 robot body hierarchy from URDF compilation (correct mesh alignment).
       Scene elements (table, stone, actuators, suction) added on top. -->

  <compiler angle="radian" meshdir="meshes" balanceinertia="true"/>

  <option gravity="0 0 -9.81" timestep="0.002" solver="Newton" iterations="50" tolerance="1e-10">
    <flag warmstart="enable"/>
  </option>

  <visual>
    <global offwidth="1280" offheight="720"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <headlight diffuse="0.3 0.3 0.3" ambient="0.15 0.15 0.15" specular="0 0 0"/>
  </visual>

  <default>
    <joint armature="0.01" damping="2.0"/>
    <geom condim="4" friction="1.0 0.5 0.01" solimp="0.95 0.99 0.001" solref="0.008 1"/>
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.95 0.95 0.95" rgb2="0.8 0.8 0.8"
             width="512" height="512"/>
    <material name="floor_mat" texture="grid" texrepeat="8 8" reflectance="0.1"/>
    <material name="table_mat" rgba="0.82 0.71 0.55 1" specular="0.2" shininess="0.5"/>
    <material name="robot_white" rgba="0.95 0.95 0.95 1" specular="0.3" shininess="0.6"/>
    <material name="robot_dark" rgba="0.25 0.25 0.25 1" specular="0.4" shininess="0.7"/>
    <material name="stone_black" rgba="0.08 0.08 0.08 1" specular="0.5" shininess="0.8"/>
    <material name="target_green" rgba="0.2 0.8 0.2 0.4"/>
    <!-- Robot link meshes (STL from franka_description) -->
    <mesh name="link0" file="link0.stl"/>
    <mesh name="link1" file="link1.stl"/>
    <mesh name="link2" file="link2.stl"/>
    <mesh name="link3" file="link3.stl"/>
    <mesh name="link4" file="link4.stl"/>
    <mesh name="link5" file="link5.stl"/>
    <mesh name="link6" file="link6.stl"/>
    <mesh name="link7" file="link7.stl"/>
    <mesh name="cobot_pump" file="cobot_pump.stl"/>
    <mesh name="go_stone_mesh" file="go_stone.obj"/>
  </asset>

  <worldbody>
    <!-- Floor -->
    <geom name="floor" type="plane" size="2 2 0.01" material="floor_mat" conaffinity="1" contype="1"/>
    <light name="top_light" pos="0.5 0 2.0" dir="0 0 -1" diffuse="0.4 0.4 0.4" specular="0.1 0.1 0.1" castshadow="true"/>
    <light name="side_light" pos="0 1.0 1.5" dir="0 -0.4 -0.8" diffuse="0.2 0.2 0.2"/>

    <!-- Cameras -->
    <camera name="front_view" pos="0.9 -0.7 0.8" xyaxes="0.7 0.7 0 -0.3 0.3 0.9"/>
    <camera name="top_view" pos="0.4 0 1.5" euler="0 0 0" fovy="60"/>

    <!-- Table -->
    <body name="table" pos="0.45 0 0">
      <geom name="table_top" type="box" size="0.3 0.3 0.005" material="table_mat"
            mass="20" conaffinity="1" contype="1"/>
      <geom type="cylinder" size="0.02 0.25" pos=" 0.25  0.25 -0.255" rgba="0.5 0.4 0.3 1"/>
      <geom type="cylinder" size="0.02 0.25" pos="-0.25  0.25 -0.255" rgba="0.5 0.4 0.3 1"/>
      <geom type="cylinder" size="0.02 0.25" pos=" 0.25 -0.25 -0.255" rgba="0.5 0.4 0.3 1"/>
      <geom type="cylinder" size="0.02 0.25" pos="-0.25 -0.25 -0.255" rgba="0.5 0.4 0.3 1"/>
    </body>

    <!-- Target placement indicator -->
    <site name="target_site" pos="0.5 0.15 0.006" size="0.015 0.001" type="cylinder"
          material="target_green"/>

    <!-- ============================================================ -->
    <!-- FR3 Robot — body hierarchy from URDF compilation             -->
    <!-- Mesh geoms have NO explicit quat: MuJoCo auto-alignment     -->
    <!-- matches the URDF body frames exactly.                        -->
    <!-- ============================================================ -->
    <body name="link0" pos="0 0 0">
      <geom name="link0_viz" type="mesh" mesh="link0" material="robot_white"
            contype="0" conaffinity="0"/>

      <body name="link1" pos="0 0 0.333">
        <inertial pos="0 -0.018 -0.039" quat="0.998098 -0.0605364 0.00380499 0.0110109"
                  mass="2.9275" diaginertia="0.024 0.023 0.006"/>
        <joint name="j1" axis="0 0 1" range="-2.9007 2.9007" damping="10" armature="0.1"/>
        <geom name="link1_viz" type="mesh" mesh="link1" material="robot_white"
              contype="0" conaffinity="0"/>

        <body name="link2" quat="0.707107 -0.707107 0 0">
          <inertial pos="0.003 -0.074 0.009" quat="0.502599 0.584437 -0.465998 0.434366"
                    mass="2.9355" diaginertia="0.063 0.041 0.025"/>
          <joint name="j2" axis="0 0 1" range="-1.8361 1.8361" damping="10" armature="0.1"/>
          <geom name="link2_viz" type="mesh" mesh="link2" material="robot_white"
                contype="0" conaffinity="0"/>

          <body name="link3" pos="0 -0.316 0" quat="0.707107 0.707107 0 0">
            <inertial pos="0.041 -0.005 -0.029" quat="0.921025 -0.244161 0.155272 0.260745"
                      mass="2.2449" diaginertia="0.027 0.019 0.017"/>
            <joint name="j3" axis="0 0 1" range="-2.9007 2.9007" damping="10" armature="0.1"/>
            <geom name="link3_viz" type="mesh" mesh="link3" material="robot_white"
                  contype="0" conaffinity="0"/>

            <body name="link4" pos="0.0825 0 0" quat="0.707107 0.707107 0 0">
              <inertial pos="-0.046 0.063 -0.009" quat="0.438018 0.803311 0.00937812 0.403414"
                        mass="2.6156" diaginertia="0.051 0.037 0.016"/>
              <joint name="j4" axis="0 0 1" range="-3.077 -0.1169" damping="10" armature="0.1"/>
              <geom name="link4_viz" type="mesh" mesh="link4" material="robot_white"
                    contype="0" conaffinity="0"/>

              <body name="link5" pos="-0.0825 0.384 0" quat="0.707107 -0.707107 0 0">
                <inertial pos="-0.002 0.029 -0.097" quat="0.919031 0.125604 0.0751531 -0.366003"
                          mass="2.3271" diaginertia="0.058 0.045 0.013"/>
                <joint name="j5" axis="0 0 1" range="-2.8763 2.8763" damping="5" armature="0.05"/>
                <geom name="link5_viz" type="mesh" mesh="link5" material="robot_white"
                      contype="0" conaffinity="0"/>

                <body name="link6" quat="0.707107 0.707107 0 0">
                  <inertial pos="0.060 -0.041 -0.010" quat="0.621301 0.552665 0.510011 0.220081"
                            mass="1.8170" diaginertia="0.018 0.016 0.002"/>
                  <joint name="j6" axis="0 0 1" range="0.4398 4.6216" damping="5" armature="0.05"/>
                  <geom name="link6_viz" type="mesh" mesh="link6" material="robot_white"
                        contype="0" conaffinity="0"/>

                  <body name="link7" pos="0.088 0 0" quat="0.707107 0.707107 0 0">
                    <inertial pos="0.002 0.003 0.099" quat="0.970629 0.0286876 -0.00706505 -0.238758"
                              mass="1.6371" diaginertia="0.015 0.015 0.001"/>
                    <joint name="j7" axis="0 0 1" range="-3.0508 3.0508" damping="2" armature="0.02"/>
                    <geom name="link7_viz" type="mesh" mesh="link7" material="robot_dark"
                          contype="0" conaffinity="0"/>

                    <!-- Cobot pump (flange + pump combined, from URDF compilation) -->
                    <geom name="pump_viz" type="mesh" mesh="cobot_pump"
                          pos="0 0 0.107" quat="0.92388 0 0 -0.382683"
                          material="robot_dark" contype="0" conaffinity="0"/>

                    <!-- TCP body at flange + pump offset -->
                    <body name="tcp" pos="0 0 0.107" quat="0.92388 0 0 -0.382683">
                      <body name="tcp_tip" pos="0 0 0.1034">
                        <site name="tcp_site" pos="0 0 -0.019" size="0.005" rgba="1 0 0 1" type="sphere"/>
                        <!-- Suction cup -->
                        <geom name="suction_neck" type="cylinder" size="0.008 0.008"
                              pos="0 0 -0.008" rgba="0.15 0.15 0.15 1" mass="0.02"
                              contype="0" conaffinity="0"/>
                        <geom name="suction_cup" type="cylinder" size="0.018 0.003"
                              pos="0 0 -0.019" rgba="0.25 0.1 0.1 1" mass="0.03"
                              contype="1" conaffinity="1"/>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- ============================================================ -->
    <!-- Go Stone (biconvex mesh, free body)                          -->
    <!-- ============================================================ -->
    <body name="stone" pos="0.2 -0.25 0.0094">
      <freejoint name="stone_free"/>
      <inertial pos="0 0 0" mass="0.0068"
                diaginertia="2.48e-07 2.48e-07 4.08e-07"/>
      <geom name="stone_geom" type="mesh" mesh="go_stone_mesh"
            material="stone_black" mass="0.0068"
            friction="1.0 0.5 0.01" condim="4"
            contype="1" conaffinity="1"/>
    </body>
  </worldbody>

  <!-- Torque actuators for computed torque control -->
  <actuator>
    <motor name="tau_j1" joint="j1"/>
    <motor name="tau_j2" joint="j2"/>
    <motor name="tau_j3" joint="j3"/>
    <motor name="tau_j4" joint="j4"/>
    <motor name="tau_j5" joint="j5"/>
    <motor name="tau_j6" joint="j6"/>
    <motor name="tau_j7" joint="j7"/>
  </actuator>

  <!-- Suction weld constraint -->
  <equality>
    <weld name="suction_weld" body1="tcp_tip" body2="stone" active="false"
          solref="0.005 1" solimp="0.95 0.99 0.001"/>
  </equality>

  <!-- Exclude contacts between adjacent robot links -->
  <contact>
    <exclude body1="link0" body2="link1"/>
    <exclude body1="link1" body2="link2"/>
    <exclude body1="link2" body2="link3"/>
    <exclude body1="link3" body2="link4"/>
    <exclude body1="link4" body2="link5"/>
    <exclude body1="link5" body2="link6"/>
    <exclude body1="link6" body2="link7"/>
  </contact>

  <keyframe>
    <key name="home"
         qpos="0 -0.569 0 -2.810 0 3.037 0.741
               0.2 -0.25 0.0094 1 0 0 0"
         ctrl="0 0 0 0 0 0 0"/>
  </keyframe>
</mujoco>
